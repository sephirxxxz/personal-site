---
interface Props {
  title?: string;
  label?: string;
  variant?: 'default' | 'featured' | 'secondary';
}

const { title, label, variant = 'default' } = Astro.props;
const variantClass = variant === 'default' ? '' : ` card--${variant}`;
---

<div class={`card${variantClass}`}>
  {label && <div class="label">{label}</div>}
  {title && <h3>{title}</h3>}
  <slot />
</div>
