---
interface Props {
  title?: string;
  label?: string;
  variant?: 'default' | 'featured' | 'secondary';
  accent?: string;
}

const { title, label, variant = 'default', accent } = Astro.props;
const variantClass = variant === 'default' ? '' : ` card--${variant}`;
const accentClass = accent ? ` card--accent-${accent}` : '';
---

<div class={`card${variantClass}${accentClass}`}>
  {label && <div class="label">{label}</div>}
  {title && <h3><Fragment set:html={title} /></h3>}
  <slot />
</div>
