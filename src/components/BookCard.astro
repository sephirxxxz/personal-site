---
interface Props {
  cover: string;
  title: string;
  author: string;
  note: string;
}

const { cover, title, author, note } = Astro.props;
const plainTitle = title.replace(/<[^>]*>/g, '');
---

<div class="book-card">
  <img src={cover} alt={plainTitle} class="book-cover" loading="lazy" />
  <div class="book-info">
    <div class="label">{author}</div>
    <h3><Fragment set:html={title} /></h3>
    <p><Fragment set:html={note} /></p>
  </div>
</div>
